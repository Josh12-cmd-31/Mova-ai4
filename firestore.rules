rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: sessions
    // Document ID: sessionId
    // Fields:
    //   - id: string (required) - Unique identifier for the session.
    //   - userId: string (required) - The UID of the user who owns this session.
    //   - title: string (required) - The title of the chat session.
    //   - messages: list (required) - The list of messages in the session.
    //   - createdAt: number (required) - Timestamp when the session was created.
    //   - updatedAt: number (required) - Timestamp when the session was last updated.
    //
    // Collection: session_files
    // Document ID: fileId
    // Fields:
    //   - id: string (required) - Unique identifier for the file.
    //   - sessionId: string (required) - The ID of the session this file belongs to.
    //   - data: string (required) - The base64 encoded file data.
    //   - mimeType: string (required) - The MIME type of the file.
    //   - createdAt: number (required) - Timestamp when the file was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSessionOwner(sessionId) {
      return isAuthenticated() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "n6690680@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidSession(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'messages', 'createdAt', 'updatedAt']) &&
             data.id is string &&
             data.userId is string &&
             data.title is string && data.title.size() <= 100 &&
             data.messages is list && data.messages.size() <= 1000 &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    function isValidSessionFile(data) {
      return data.keys().hasAll(['id', 'sessionId', 'data', 'mimeType', 'createdAt']) &&
             data.id is string &&
             data.sessionId is string &&
             data.data is string && data.data.size() <= 1048576 && // Max 1MB
             data.mimeType is string &&
             data.createdAt is number;
    }

    function isValidOrchestrationConfig(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'globalContext', 'agents', 'createdAt', 'updatedAt']) &&
             data.id is string &&
             data.userId is string &&
             data.name is string && data.name.size() <= 100 &&
             data.globalContext is string && data.globalContext.size() <= 5000 &&
             data.agents is list && data.agents.size() <= 10 &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /orchestration_configs/{configId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && 
                      isValidOrchestrationConfig(request.resource.data) && 
                      isOwner(request.resource.data.userId);
      allow update: if isAuthenticated() && 
                      isValidOrchestrationConfig(request.resource.data) && 
                      isOwner(resource.data.userId) && 
                      request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /session_files/{fileId} {
      allow read: if isAuthenticated() && isSessionOwner(resource.data.sessionId);
      allow create: if isAuthenticated() && 
                      isValidSessionFile(request.resource.data) && 
                      isSessionOwner(request.resource.data.sessionId);
      allow delete: if isAuthenticated() && isSessionOwner(resource.data.sessionId);
    }

    match /sessions/{sessionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      allow create: if isAuthenticated() && 
                      isValidSession(request.resource.data) && 
                      isOwner(request.resource.data.userId);
      
      allow update: if isAuthenticated() && 
                      isValidSession(request.resource.data) && 
                      isOwner(resource.data.userId) && 
                      request.resource.data.userId == resource.data.userId;
      
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
